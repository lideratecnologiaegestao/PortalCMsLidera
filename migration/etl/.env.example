# =====================================================================
# ETL MySQL (Laravel old) -> PostgreSQL (plataforma nova) — config por env
# Copie para `.env` e ajuste. NUNCA commitar o `.env` com credenciais reais.
# =====================================================================

# --- Origem: MySQL do sistema Laravel antigo (portal-camara-old) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=portal_camara_old
MYSQL_USER=root
MYSQL_PASSWORD=
# Charset do dump antigo. Laravel 12 usa utf8mb4 por padrão.
MYSQL_CHARSET=utf8mb4

# --- Destino: PostgreSQL 16 da plataforma nova (portal-camara) ---
# Pode usar PGHOST/PGUSER/... OU uma única DATABASE_URL (tem prioridade).
# DATABASE_URL=postgres://camara:senha@127.0.0.1:5432/portal_camara
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=portal_camara
PGUSER=camara
PGPASSWORD=
# Quando o destino exige TLS (RDS/Cloud), defina PGSSLMODE=require.
PGSSLMODE=disable

# --- Tenant alvo da carga ---
# O ETL resolve/cria o tenant por SLUG. Todas as linhas migradas recebem este tenant_id.
TENANT_SLUG=serra-nova-dourada-mt
TENANT_NOME=Câmara Municipal de Serra Nova Dourada
TENANT_UF=MT
TENANT_MUNICIPIO_IBGE=5107875
# Se 'true' e o tenant não existir, o ETL cria o registro em `tenants`.
TENANT_CREATE_IF_MISSING=true

# --- Comportamento do ETL ---
# Lote de INSERT no Postgres (linhas por statement multi-VALUES).
BATCH_SIZE=500
# 'true' = não escreve nada (apenas lê origem, transforma e conta). Igual a --dry-run.
DRY_RUN=false
# Nível de log: error | warn | info | debug
LOG_LEVEL=info

# --- Tratamento de senhas (ver README, seção "Re-hash de senhas") ---
# Como migrar `users.password` do Laravel (bcrypt $2y$) para a plataforma nova:
#   preserve  -> copia o hash bcrypt como está (a API deve aceitar $2y$/$2a$ no login).
#   reset     -> NÃO copia senha; marca o usuário p/ "primeiro acesso" (reset por e-mail).
PASSWORD_STRATEGY=preserve
# Sufixo opcional p/ e-mails de papéis administrativos em ambiente de staging
# (evita disparo acidental de e-mail real durante testes). Vazio em produção.
EMAIL_SANDBOX_SUFFIX=

# --- Storage / mídia ---
# O ETL NÃO faz upload binário (regra: upload sempre via API). Ele apenas
# PRESERVA os caminhos/URLs antigos em colunas *_url e deixa storage_key NULL,
# para que um passo posterior (re-hospedagem via API) os preencha. Defina aqui
# o prefixo público do legado caso queira materializar URLs absolutas.
LEGADO_PUBLIC_BASE_URL=https://www.serranovadourada.mt.leg.br
